---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  author?: string;
}

const {
  title = 'TopGun — Real-time apps that survive offline.',
  description = 'Local writes are instant. Reconnect and everything syncs. CRDT conflict handling is built in. Self-hostable, Apache 2.0.',
  image,
  type = 'website',
  publishedTime,
  author,
} = Astro.props;

// Normalize pathname: at build time Astro.url.pathname carries the literal
// emitted file path (e.g. `/docs/intro.html` because build.format === 'file'),
// but the deployed URLs are clean (no .html, no trailing slash). Strip both so
// canonical, og:url, twitter:url, and the derived og:image path stay aligned
// with what Cloudflare actually serves.
const rawPathname = Astro.url.pathname;
const pathname = rawPathname === '/'
  ? '/'
  : rawPathname.replace(/\.html$/, '').replace(/\/$/, '');
const canonicalURL = new URL(pathname, Astro.site);

// Generate dynamic OG image URL based on current path. The root path resolves
// to /og.png (served by src/pages/og.png.ts); every other page resolves to the
// matching pre-rendered image under /og/<path>.png.
const ogImagePath = pathname === '/' ? '/og.png' : `/og${pathname}.png`;
const imageURL = new URL(image || ogImagePath, Astro.site);
---

<!-- Primary Meta Tags -->
<meta name="title" content={title} />
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
<link rel="alternate" type="application/rss+xml" title="TopGun Blog RSS Feed" href={new URL('/rss.xml', Astro.site)} />

<!-- Favicons + PWA -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#0a0e14" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:site_name" content="TopGun" />
<meta property="og:locale" content="en_US" />

{type === 'article' && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{type === 'article' && author && (
  <meta property="article:author" content={author} />
)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />

<!-- JSON-LD Structured Data -->
{type === 'website' && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "TopGun",
    "description": description,
    "url": Astro.site?.toString(),
    "publisher": {
      "@type": "Organization",
      "name": "TopGun",
      "url": Astro.site?.toString()
    }
  })} />
)}

{type === 'article' && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "url": canonicalURL.toString(),
    "image": imageURL.toString(),
    "datePublished": publishedTime,
    "author": {
      "@type": "Person",
      "name": author
    },
    "publisher": {
      "@type": "Organization",
      "name": "TopGun",
      "url": Astro.site?.toString()
    }
  })} />
)}
