---
const links = [
  { heading: 'Product', items: [
    { href: '/docs/quickstart', label: 'Quickstart' },
    { href: '/docs', label: 'Documentation' },
    { href: '#how', label: 'How it works' },
  ]},
  { heading: 'Open source', items: [
    { href: 'https://github.com/TopGunBuild/topgun', label: 'GitHub', external: true },
    { href: 'https://github.com/TopGunBuild/topgun/blob/main/LICENSE', label: 'Apache 2.0', external: true },
    { href: '/docs/changelog', label: 'Changelog' },
  ]},
  { heading: 'Community', items: [
    { href: '/blog', label: 'Blog' },
  ]},
];
---

<footer style="border-top: 1px solid var(--color-border); background-color: var(--color-bg-sunken);">
  <div class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid grid-cols-2 gap-10 md:grid-cols-4">
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2.5 font-semibold" style="color: var(--color-fg)">
          <svg width="22" height="22" viewBox="0 0 32 32" aria-hidden="true">
            <circle cx="16" cy="16" r="13" fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-opacity="0.4" />
            <circle cx="16" cy="16" r="8"  fill="none" stroke="var(--color-accent)" stroke-width="1.5" stroke-opacity="0.7" />
            <line x1="16" y1="16" x2="27" y2="11" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" />
            <circle cx="16" cy="16" r="2" fill="var(--color-accent)" />
          </svg>
          TopGun
        </div>
        <p class="mt-3 max-w-xs text-sm leading-relaxed" style="color: var(--color-fg-muted)">
          Real-time apps that survive offline. Open source. Self-hostable.
        </p>
      </div>

      {
        links.map((group) => (
          <div>
            <p
              class="font-mono text-xs uppercase tracking-wider"
              style="color: var(--color-fg-dim)"
            >
              {group.heading}
            </p>
            <ul class="mt-4 space-y-2.5 text-sm" style="color: var(--color-fg-muted)">
              {group.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="transition-colors hover:text-[var(--color-fg)]"
                    {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-12 flex flex-wrap items-center justify-between gap-3 pt-6 font-mono text-xs"
      style="border-top: 1px solid var(--color-border); color: var(--color-fg-dim)"
    >
      <span>~ topgun · apache 2.0 · self-hostable</span>
      <span>made for the offline-first web</span>
    </div>
  </div>
</footer>
