---
/**
 * Built for production — three outcome cards (not feature dump).
 * Each card pairs a short headline outcome with a one-paragraph "what that
 * actually means" body, plus a small mono-line "proof" footer.
 *
 * Icons are inline SVG — radar-adjacent geometric primitives so they
 * cohabit with the hero scope visually.
 */

const cards = [
  {
    title: 'Local-first, by design',
    body: 'Every read is in-memory. Every write is optimistic. Offline is the default state, not the error state — the app keeps working when the network does not.',
    proof: '~ in-memory reads · optimistic writes',
    icon: 'pulse',
  },
  {
    title: 'CRDTs handle the merge',
    body: 'No conflict UI. No last-write-wins surprises. Hybrid logical clocks order events; CRDTs converge them deterministically. Math, not heuristics.',
    proof: '~ deterministic · convergent · no manual merge',
    icon: 'merge',
  },
  {
    title: 'Self-host. Apache 2.0.',
    body: 'A single Rust binary on the server. Embedded storage out of the box. Swap in your own database when scale demands. No vendor, no lock-in.',
    proof: '~ one binary · embedded storage · apache 2.0',
    icon: 'shield',
  },
];
---

<section style="background-color: var(--color-bg-sunken)">
  <div class="mx-auto max-w-6xl px-6 py-28 md:py-36">
    <div class="mx-auto mb-14 max-w-2xl text-center">
      <p class="section-label">~ fundamentals</p>
      <h2
        class="mt-3 text-4xl font-bold tracking-tight md:text-5xl"
        style="color: var(--color-fg); line-height: 1.1;"
      >
        No tricks.<br />
        <span style="color: var(--color-accent)">Just fundamentals.</span>
      </h2>
      <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed" style="color: var(--color-fg-muted)">
        TopGun is built on durable primitives — local-first storage, CRDTs,
        hybrid logical clocks. Boring under the hood, magic on the surface.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
      {
        cards.map((c) => (
          <article
            class="relative overflow-hidden rounded-xl p-6 md:p-7"
            style="background-color: var(--color-bg-elevated); border: 1px solid var(--color-border);"
          >
            <div
              class="mb-5 flex h-11 w-11 items-center justify-center rounded-md"
              style="background-color: color-mix(in oklab, var(--color-accent) 12%, transparent); border: 1px solid var(--color-accent-soft);"
            >
              {c.icon === 'pulse' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.7" stroke-linecap="round">
                  <path d="M2 12 h4 l2 -6 l4 12 l2 -6 h8" />
                </svg>
              )}
              {c.icon === 'merge' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="6"  cy="5"  r="2.2" />
                  <circle cx="6"  cy="19" r="2.2" />
                  <circle cx="18" cy="12" r="2.2" />
                  <path d="M6 7 Q 14 9 16 11" />
                  <path d="M6 17 Q 14 15 16 13" />
                </svg>
              )}
              {c.icon === 'shield' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 3 L20 6 V12 C20 17 16 21 12 22 C8 21 4 17 4 12 V6 Z" />
                  <path d="M9 12 l2 2 l4 -4" />
                </svg>
              )}
            </div>

            <h3 class="text-xl font-semibold" style="color: var(--color-fg); line-height: 1.3;">
              {c.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed" style="color: var(--color-fg-muted)">
              {c.body}
            </p>

            <p
              class="mt-6 font-mono text-[11px]"
              style="color: var(--color-fg-dim); border-top: 1px solid var(--color-border); padding-top: 16px;"
            >
              {c.proof}
            </p>
          </article>
        ))
      }
    </div>

    <!-- CTA strip — invites the reader to actually start -->
    <div
      class="mt-14 flex flex-wrap items-center justify-between gap-6 rounded-xl p-6 md:px-8 md:py-7"
      style="background-color: var(--color-bg-elevated); border: 1px solid var(--color-border);"
    >
      <div>
        <p class="section-label">~ next.step</p>
        <p class="mt-2 text-xl font-semibold" style="color: var(--color-fg)">
          Ready to try it for real?
        </p>
        <p class="mt-1 text-sm" style="color: var(--color-fg-muted)">
          One command to scaffold a working real-time app on your machine.
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <a
          href="/docs/quickstart"
          class="rounded-md px-5 py-3 text-sm font-semibold transition-transform hover:scale-[1.02]"
          style="background-color: var(--color-accent); color: var(--color-bg); box-shadow: 0 0 0 1px var(--color-accent-strong), 0 8px 24px -8px var(--color-accent-soft);"
        >
          Start in 60 seconds &rarr;
        </a>
        <a
          href="https://github.com/TopGunBuild/topgun"
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-md px-5 py-3 text-sm font-medium transition-colors hover:bg-[var(--color-bg-sunken)]"
          style="border: 1px solid var(--color-border-strong); color: var(--color-fg)"
        >
          GitHub &rarr;
        </a>
      </div>
    </div>
  </div>
</section>
