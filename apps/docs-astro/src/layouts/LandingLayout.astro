---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import PostHog from '../components/PostHog.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'TopGun — Real-time apps that survive offline.',
  description = 'Local writes are instant. Reconnect and everything syncs. CRDT conflict handling is built in. Self-hostable, Apache 2.0.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <SEO title={title} description={description} type="website" />
    <meta name="theme-color" content="#0a0e14" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <PostHog />
  </head>
  <body
    class="font-sans"
    style="background-color: var(--color-bg); color: var(--color-fg); min-height: 100vh;"
  >
    <slot />
  </body>
</html>
