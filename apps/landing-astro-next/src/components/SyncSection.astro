---
/**
 * Sync visualization section — narrates what happens on reconnect.
 * Three small "moments" stacked: disconnect → both edit offline → reconnect & merge.
 */

const moments = [
  {
    label: '01',
    title: 'Both devices offline',
    body: 'Plane mode, dead zone, bad hotel wifi. Every edit applies locally and stays there.',
    state: 'offline',
  },
  {
    label: '02',
    title: 'Two people edit the same list',
    body: 'No coordination, no locks, no shared cursor. Just edits.',
    state: 'editing',
  },
  {
    label: '03',
    title: 'Reconnect — merged automatically',
    body: 'Hybrid logical clocks order the edits. CRDTs merge them. Nothing for you to write.',
    state: 'synced',
  },
];
---

<section id="sync" class="relative">
  <div
    class="bg-dotgrid bg-dotgrid-mask pointer-events-none absolute inset-0 opacity-50"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-6xl px-6 py-28 md:py-36">
    <div class="mx-auto mb-14 max-w-2xl text-center">
      <p class="section-label">~ sync.in.action</p>
      <h2
        class="mt-3 text-4xl font-bold tracking-tight md:text-5xl"
        style="color: var(--color-fg); line-height: 1.1;"
      >
        Two devices.<br />
        <span style="color: var(--color-accent)">One source of truth.</span>
      </h2>
      <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed" style="color: var(--color-fg-muted)">
        Edit anywhere, online or off. Reconnect and edits converge — no manual
        conflict UI, no overwrites, no lost work.
      </p>
    </div>

    <ol class="grid grid-cols-1 gap-5 md:grid-cols-3">
      {
        moments.map((m) => (
          <li
            class="relative overflow-hidden rounded-xl p-7"
            style="background-color: var(--color-bg-elevated); border: 1px solid var(--color-border);"
          >
            <div class="flex items-center justify-between">
              <span
                class="font-mono text-xs"
                style="color: var(--color-fg-dim)"
              >
                {m.label}
              </span>
              <span
                class="rounded-full px-2 py-0.5 font-mono text-[11px]"
                style={
                  m.state === 'synced'
                    ? 'background-color: color-mix(in oklab, var(--color-accent) 18%, transparent); color: var(--color-accent);'
                    : m.state === 'editing'
                      ? 'background-color: var(--color-warn-soft); color: var(--color-warn);'
                      : 'background-color: var(--color-bg-sunken); color: var(--color-fg-dim); border: 1px solid var(--color-border);'
                }
              >
                {m.state}
              </span>
            </div>

            <h3
              class="mt-5 text-xl font-semibold"
              style="color: var(--color-fg); line-height: 1.3;"
            >
              {m.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed" style="color: var(--color-fg-muted)">
              {m.body}
            </p>

            <div class="mt-7 flex items-center justify-between font-mono text-[11px]" style="color: var(--color-fg-dim)">
              <div class="flex items-center gap-2">
                <span
                  class={m.state === 'synced' ? 'node-blink' : ''}
                  style={`width: 8px; height: 8px; border-radius: 50%; background-color: ${
                    m.state === 'synced'
                      ? 'var(--color-accent)'
                      : m.state === 'editing'
                        ? 'var(--color-warn)'
                        : 'var(--color-fg-dim)'
                  }`}
                />
                device.a
              </div>
              <div
                class="mx-3 flex-1 border-t border-dashed"
                style={`border-color: ${
                  m.state === 'synced' ? 'var(--color-accent-soft)' : 'var(--color-border)'
                }`}
              />
              <div class="flex items-center gap-2">
                device.b
                <span
                  class={m.state === 'synced' ? 'node-blink' : ''}
                  style={`width: 8px; height: 8px; border-radius: 50%; background-color: ${
                    m.state === 'synced'
                      ? 'var(--color-accent)'
                      : m.state === 'editing'
                        ? 'var(--color-warn)'
                        : 'var(--color-fg-dim)'
                  }`}
                />
              </div>
            </div>
          </li>
        ))
      }
    </ol>

    <!-- Live demo CTA — opens the working sync lab on a separate origin -->
    <div class="mt-14 flex flex-col items-center gap-4">
      <a
        href="https://demo.topgun.build/"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-md px-5 py-3 text-sm font-semibold transition-transform hover:scale-[1.02]"
        style="background-color: var(--color-accent); color: var(--color-bg); box-shadow: 0 0 0 1px var(--color-accent-strong), 0 8px 24px -8px var(--color-accent-soft);"
      >
        See the merge happen live
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 17 L17 7" />
          <path d="M9 7 L17 7 L17 15" />
        </svg>
      </a>
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-2 font-mono text-xs" style="color: var(--color-fg-dim)">
        <span>~ crdt-based merge</span>
        <span>~ hybrid logical clocks</span>
        <span>~ no manual conflict ui</span>
      </div>
    </div>
  </div>
</section>
