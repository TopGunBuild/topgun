{
  "name": "@topgunbuild/server",
  "version": "2.0.0",
  "description": "TopGun server — prebuilt binary distribution. Zero Rust toolchain required.",
  "private": false,
  "license": "Apache-2.0",
  "bin": {
    "topgun-server": "./bin/topgun-server.cjs"
  },
  "optionalDependencies": {
    "@topgunbuild/server-darwin-arm64": "2.0.0",
    "@topgunbuild/server-linux-x64": "2.0.0"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.cjs"
  },
  "files": [
    "bin",
    "scripts",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TopGunBuild/topgun.git",
    "directory": "packages/server-dist"
  },
  "keywords": [
    "topgun",
    "server",
    "realtime",
    "offline-first",
    "crdt",
    "websocket",
    "redb"
  ]
}
